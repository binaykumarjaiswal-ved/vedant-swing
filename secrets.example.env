# Copy to secrets.env locally — NEVER commit secrets.env

# Optional Telegram alerts (add in GitHub Secrets, not here)
# TELEGRAM_BOT_TOKEN=your_token_from_BotFather
# TELEGRAM_CHAT_ID=your_chat_id

# Render web app — sync state from private GitHub repo
# GITHUB_REPO=binaykumarjaiswal-ved/vedant-swing
# GITHUB_TOKEN=your_github_pat_with_repo_scope

# Groq — prefer encrypted setup (see SETUP_GROQ_KEY.txt + ACTIVATE-GROQ.bat)
# Paste key in local-secrets/groq-key-PASTE-HERE.txt then run ACTIVATE-GROQ.bat
# GROQ_API_KEY=your_groq_key
# AI_ENABLED=true

STOCK_SCAN_LIMIT=500

# Gmail email alerts (see SETUP_GMAIL_ALERTS.txt)
EMAIL_ENABLED=false
EMAIL_FROM=vedantswing.alerts@gmail.com
EMAIL_TO=your-personal-email@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password