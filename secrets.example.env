# Copy to secrets.env locally — NEVER commit secrets.env

# Optional Telegram alerts (add in GitHub Secrets, not here)
# TELEGRAM_BOT_TOKEN=your_token_from_BotFather
# TELEGRAM_CHAT_ID=your_chat_id

# Render web app — sync state from private GitHub repo
# GITHUB_REPO=binaykumarjaiswal-ved/vedant-swing
# GITHUB_TOKEN=your_github_pat_with_repo_scope

# Optional AI (disabled by default in Vedant Swing)
# GROQ_API_KEY=your_groq_key
# AI_ENABLED=false

STOCK_SCAN_LIMIT=500